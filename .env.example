DATABASE_URL="postgresql://vpn_user:vpn_pass@postgres:5432/vpn_shop?schema=public"
REDIS_URL="redis://redis:6379"
AUTH_SECRET="replace-with-random-secret"
NEXTAUTH_SECRET="replace-with-random-secret"
OWNER_BOOTSTRAP_TOKEN="replace-with-strong-one-time-token"
APP_DOMAIN="vpn.your-domain.ru"
ACME_EMAIL="you@your-domain.ru"
CHECKOUT_ENABLED="true"

YOOKASSA_SHOP_ID="replace"
YOOKASSA_SECRET_KEY="replace"
YOOKASSA_RETURN_URL="https://your-domain.ru/account"
YOOKASSA_WEBHOOK_IP_ALLOWLIST_ENABLED="false"
YOOKASSA_WEBHOOK_ALLOWED_IPS=""
YOOKASSA_WEBHOOK_RATE_LIMIT_RPM="60"

REMNAWAVE_API_URL="https://your-remnawave-host"
REMNAWAVE_API_KEY="replace"
REMNAWAVE_API_HEADER_NAME="Authorization"
REMNAWAVE_API_HEADER_PREFIX="Bearer"

REFERRAL_INVITER_BONUS_DAYS="7"
REFERRAL_INVITED_BONUS_DAYS="3"

ALLOWED_EMAIL_DOMAINS="gmail.com,googlemail.com,yandex.ru,ya.ru,mail.ru,inbox.ru,list.ru,bk.ru,icloud.com,me.com,outlook.com,hotmail.com,live.com,msn.com,yahoo.com,proton.me,protonmail.com"
RESEND_API_KEY="re_xxxxxxxxx"
RESEND_FROM="VPN Shop <no-reply@your-domain.ru>"

REMNASHOP_DATABASE_URL="postgresql://readonly_user:readonly_pass@bot-postgres:5432/remnashop"
REMNASHOP_DB_POOL_MAX="5"
REMNASHOP_DB_IDLE_MS="10000"
REMNASHOP_DB_CONNECT_TIMEOUT_MS="5000"
REMNASHOP_DB_SSL="false"
REMNASHOP_DB_SSL_REJECT_UNAUTHORIZED="true"

TELEGRAM_BOT_TOKEN="replace"
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME="your_bot_username"
TELEGRAM_AUTH_MAX_AGE_SECONDS="300"
